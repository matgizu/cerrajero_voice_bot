# ============================================================
# CERRAJERO VOICE AGENT — Variables de Entorno
# ============================================================
# Copia este archivo como .env y reemplaza los valores

# ── ElevenLabs ───────────────────────────────────────────────
# API Key → elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Agent ID → Conversational AI → tu agente → Settings → Agent ID
ELEVENLABS_AGENT_ID=

# ── Twilio (para llamadas telefónicas) ───────────────────────
# Obtén estas credenciales en twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# URL pública del servidor (ngrok en desarrollo, dominio real en producción)
# Usada para el webhook de Twilio Media Streams
# Ejemplo: https://abc123.ngrok.io
PUBLIC_URL=

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Gemini (legacy — solo si usas la interfaz browser con Gemini) ──
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-live-001
AGENT_VOICE=Charon
